{
    "name": "psc-acme/monitor-cart",
    "description": "Package monitor-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\MonitorCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "guzzlehttp/psr7": "^2.0",
        "brick/math": "^0.12",
        "psr/container": "^2.0",
        "symfony/serializer": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}